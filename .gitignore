# =================================================================
# AI Paper Replicator - Professional Git Configuration
# =================================================================

# --- Python Environment ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/

# --- Environment Variables (CRITICAL) ---
# Strictly prevent leaking any API keys or secrets
.env
.env.*
!.env.example

# --- Project Specific Data (Inputs & Outputs) ---
# Ignore all content inside these folders but keep the folders themselves
inputs/**/*
outputs/**/*

# Keep the folder structure on GitHub via .gitkeep
!.gitkeep
!inputs/.gitkeep
!outputs/.gitkeep

# --- IDEs & OS Support ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# --- Data & Logs ---
*.log
data/
temp/